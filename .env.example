# Environment variables template
# Copy this file to .env.local and fill in the values for local development
# Copy this file to .env.staging and .env.production for respective environments

# API Configuration
# Base URL of the API server
VITE_API_BASE_URL=http://localhost:3000

# Development Features
# Enable/disable mock data for testing (true/false)
# Development: true (recommended for local testing)
# Production: false (use real API)
VITE_USE_MOCK=false

# Enable/disable console logging for API requests (true/false)
VITE_ENABLE_LOGS=true

# Google Places API key (required for address autocomplete)
# Get your key at https://console.cloud.google.com — enable the "Places API"
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key
